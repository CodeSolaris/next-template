{
  "name": "next-template",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "commit": "cz",
    "prepare": "lefthook install",
    "check:types": "tsc --noEmit --pretty",
    "check": "bun run check:types && bun run lint:fix && bun run test:run && bun run storybook:test",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.ts",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@commitlint/types": "^20.4.0",
    "@elsikora/commitizen-plugin-commitlint-ai": "2.5.0",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-vitest": "^10.2.10",
    "@storybook/nextjs-vite": "^10.2.10",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "commitizen": "^4.3.1",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.2.10",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.1",
    "playwright": "^1.58.2",
    "storybook": "^10.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "lefthook",
    "sharp",
    "unrs-resolver"
  ],
  "config": {
    "commitizen": {
      "path": "@elsikora/commitizen-plugin-commitlint-ai"
    }
  }
}
